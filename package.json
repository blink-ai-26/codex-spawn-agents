{
  "name": "codex-spawn-agents",
  "version": "0.1.0",
  "description": "CLI for launching one or more Codex SDK agents in parallel",
  "type": "module",
  "bin": {
    "codex-spawn": "src/cli.ts"
  },
  "scripts": {
